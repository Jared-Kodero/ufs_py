       FNSNOC   = "FIXED/global_snoclim.1.875.grb",
       FNZORC   = "igbp",
       FNALBC   = "FIXED/fix_sfc/CXXX.snowfree_albedo.tileX.nc",
       FNALBC2  = "FIXED/fix_sfc/CXXX.facsf.tileX.nc",
       FNAISC   = "FIXED/CFSR.SEAICE.1982.2012.monthly.clim.grb",
       FNTG3C   = "FIXED/fix_sfc/CXXX.substrate_temperature.tileX.nc",
       FNVEGC   = "FIXED/fix_sfc/CXXX.vegetation_greenness.tileX.nc",
