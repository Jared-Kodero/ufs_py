       FNVMXC   = "FIXED/fix_sfc/CXXX.vegetation_greenness.tileX.nc",
       FNSLPC   = "FIXED/fix_sfc/CXXX.slope_type.tileX.nc",
       FNABSC   = "FIXED/fix_sfc/CXXX.maximum_snow_albedo.tileX.nc",
