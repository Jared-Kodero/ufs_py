       FNSOTC   = "FIXED/fix_sfc/CXXX.soil_type.tileX.nc",
       FNSMCC   = "FIXED/global_soilmgldas.t1534.3072.1536.grb",
       FNMSKH   = "FIXED/global_slmask.t1534.3072.1536.grb",
       FNTSFA   = "",
