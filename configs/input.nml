 &fms_affinity_nml
   affinity = .F.
   debug_affinity = .F.
   debug_cpuset = .F.
/

 &amip_interp_nml
     interp_oi_sst = .true.
     use_ncep_sst = .true.
     use_ncep_ice = .false.
     no_anom_sst = .false.
     data_set = 'reynolds_oi',
     date_out_of_range = 'climo',
/

 &atmos_model_nml
     blocksize = 6
     chksum_debug = .false.
     dycore_only = .F.
     fdiag = 1.
/


&field_manager_nml
   use_field_table_yaml = .true.
/

&diag_manager_nml
     !use_modern_diag = .true.
     prepend_date = .F.
   !diag_manager_forecast_mode = .T.
/

 &fms_io_nml
       checksum_required   = .false.
       max_files_r = 100,
       max_files_w = 100,
/

 &fms_nml
       clock_grain = 'ROUTINE',
       domains_stack_size = 3000000,
       print_memory_usage = .F.
/


 &fv_core_nml
       layout   = 1,1
       io_layout= 1,1
       npx      = 97 ! 211
       npy      = 97 ! 193
       ntiles   = 6,
       npz      = 63
       !grid_type = -1
       make_nh  = .F.
       fv_debug = .f.
       range_warn = .T.
       reset_eta = .F.
       nudge_qv = .T.
       d2_bg_k1 = 0.20
       d2_bg_k2 = 0.15
       kord_tm = -9 
       kord_mt =  9
       kord_wz =  9
       kord_tr =  9
       fill = .T.     
       fill_gfs = .F. 
       hydrostatic = .F.
       phys_hydrostatic = .F.
       use_hydro_pressure = .F.
       beta = 0.
       a_imp = 1.
       p_fac = 0.1
       k_split  = 1
       n_split  = 3
       nwat = 6 
       na_init = 1
       d_ext = 0.0
       dnats = 1 
       fv_sg_adj = 600 
       d2_bg = 0.
       nord =  3  
       dddmp = 0.5
       d4_bg = 0.14
       vtdm4 = 0.06
       do_vort_damp = .T.
       external_ic = .T.
       nggps_ic = .T.
       mountain = .F.
       ncep_ic = .F.
       d_con = 1.0
       hord_mt = 5
       hord_vt = 5
       hord_tm = 5
       hord_dp = 5
       hord_tr = 5 
       adjust_dry_mass = .F.
       consv_te = 0.
       consv_am = .F.
       dwind_2d = .F.
       print_freq = -6
       warm_start = .F.
       no_dycore = .F.
       rf_fast = .F.
       tau = 5.
       rf_cutoff = 50.e2
       delt_max = 0.002
       write_3d_diags = .T.

       do_schmidt = .true.
       target_lat = 30.0
       target_lon = -85.0
       stretch_fac = 1.0

/

 &integ_phys_nml                                                                                       
       do_sat_adj = .F.
       do_inline_mp = .T.
/


 &fv_nest_nml
    grid_pes = 6,2
    num_tile_top= 7
    tile_coarse = 0,6
    nest_refine = 0,3
    nest_ioffsets = 999,31
    nest_joffsets = 999,31
    p_split = 1
/


 &coupler_nml
       months = 0
       days  = 0
       hours = 3
       minutes = 0
       seconds = 0
       dt_atmos = 450
       dt_ocean = 450
       current_date =  2021,08,29,00,0,0
       calendar = 'julian'
       atmos_nthreads =1
       use_hyper_thread = .F.
/

 &external_ic_nml 
       filtered_terrain = .true.
       levp = 64
       gfs_dwinds = .true.
       checker_tr = .F.
       nt_checker = 0
/


 &gfs_physics_nml
       fhzero         = 1.
       ldiag3d        = .T.
       fhcyc          = 24.
       nst_anl        = .true.
       use_ufo        = .true.
       pre_rad        = .false.
       ncld           = 5
       zhao_mic       = .false.
       pdfcld         = .true. 
       cloud_gfdl     = .true. 
       fhswr          = 3600.
       fhlwr          = 3600.
       ialb           = 1 
       iems           = 1
       IAER           = 111
       ico2           = 2
       isubc_sw       = 2
       isubc_lw       = 2
       isol           = 2
       lwhtr          = .true.
       swhtr          = .true.
       cnvgwd         = .false.
       shal_cnv       = .true. 
       cal_pre        = .false.
       redrag         = .true.
       dspheat        = .true.
       hybedmf        = .false.
       random_clds    = .false.
       trans_trac     = .true.
       cnvcld         = .false.
       imfshalcnv     = 2
       imfdeepcnv     = 2
       cdmbgwd        = 3.5, 0.25
       prslrd0        = 0.
       ivegsrc        = 1
       isot           = 1
       debug          = .f.
       do_deep        = .true.
       do_ocean       = .true. 
       ysupbl         = .true. 
       xkzminv        = 1.0  
       xkzm_h         = 0.02  
       xkzm_m         = 0.02 
       do_z0_hwrf17_hwonly = .true.
/


 &ocean_nml 
     mld_option       = "obs"
     ocean_option     = "MLM" 
     restore_method   = 2
     mld_obs_ratio    = 1.
     use_rain_flux    = .true.
     sst_restore_tscale = 2.
     start_lat        = -45.
     end_lat          = 45.
     Gam              = 0.2
     use_old_mlm      = .true.
     do_mld_restore   = .true.
     mld_restore_tscale = 2.
     stress_ratio     = 1.
     eps_day          = 10.
/

 &gfdl_mp_nml
/


  &interpolator_nml
       interp_method = 'conserve_great_circle'
/




